<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<Title>MatFileIO</Title>
		<Authors>randolf</Authors>
		<VersionPrefix>1.0.2</VersionPrefix>
		<Description>Zero Heap Memory Allocation .mat v5.0 file IO library for C#</Description>
		<PackageProjectUrl>https://github.com/randolfly/MatFileIO</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/randolfly/MatFileIO</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>matlab; IO;</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>

</Project>
